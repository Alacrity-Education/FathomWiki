# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
EMAIL_USER=you@gmail.com
# Gmail App Password (not your regular password).
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# SSH private key for git push to git@github.com:Alacrity-Education/Wiki.git
# Paste the full key inline (newlines are preserved by Docker/Compose).
GIT_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----
...paste key here...
-----END OPENSSH PRIVATE KEY-----

# === Optional ===
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# SENDER_DOMAIN=fathom.video
# OUTPUT_DIR=/output
# MARK_AS_READ=true

# Set to seconds > 0 to poll continuously (e.g. 300 = every 5 min).
# Set to 0 (default) for a single run.
# POLL_INTERVAL=0
